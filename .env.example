# ── Database ───────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/baiying

# ── Event Bus ──────────────────────────────────────────────────────────
# Redis connection string (optional; event bus is no-op if unset)
REDIS_URL=redis://localhost:6379

# ── WebSocket ──────────────────────────────────────────────────────────
# Port for the realtime WebSocket server (default: 3001)
WS_PORT=3001

# ── Server ─────────────────────────────────────────────────────────────
# Public server URL (optional)
SERVER_URL=http://localhost:3000

# ── Client (must be prefixed with VITE_) ───────────────────────────────
VITE_APP_TITLE=Baiying Channel

# ── Video Processing ───────────────────────────────────────────────────
# Storage path for video files and extracted data (default: ./output)
VIDEO_STORAGE_PATH=./output

# Path to ffmpeg binary (default: ffmpeg)
FFMPEG_PATH=ffmpeg

# Path to whisper binary (default: whisper)
WHISPER_PATH=whisper

# Whisper model to use (default: medium)
WHISPER_MODEL=medium

# Max upload file size in MB (default: 5000)
MAX_UPLOAD_SIZE_MB=5000
