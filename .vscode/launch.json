{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev: TanStack Start (SSR)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "smartStep": true,
      "envFile": "${workspaceFolder}/.env.local"
    },
    {
      "name": "Client: Chrome (localhost:3000)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true
    },
    {
      "name": "Vitest: Current File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "smartStep": true,
      "envFile": "${workspaceFolder}/.env.local"
    },
    {
      "name": "Vitest: All",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run"],
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "smartStep": true,
      "envFile": "${workspaceFolder}/.env.local"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Server + Chrome",
      "configurations": ["Dev: TanStack Start (SSR)", "Client: Chrome (localhost:3000)"],
      "stopAll": true
    }
  ]
}
